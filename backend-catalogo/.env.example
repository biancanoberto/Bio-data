PORT=3000

# PostgreSQL
# Use DATABASE_URL for app runtime. Supabase pooler example:
DATABASE_URL="postgresql://postgres.project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use DIRECT_URL for Prisma migrations when using Supabase.
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# Supabase Storage
SUPABASE_URL="https://project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
